# Variáveis de Ambiente — Pandemic Monitor
# Copie este arquivo para .env e preencha com suas chaves reais.

# ===== CHAVES DE API (Obrigatórias) =====

# Google Gemini — Provedor primário de IA
GEMINI_API_KEY="sua_chave_gemini_aqui"

# NVIDIA NIM — Provedor secundário (DeepSeek, Llama)
NVIDIA_API_KEY="sua_chave_nvidia_aqui"

# ===== SERVIDOR =====

PORT=3001
NODE_ENV=development

# ===== ADMINISTRAÇÃO =====

# Token secreto para acionar /api/admin/force-sync
# Em produção, definir via GitHub Secrets → ADMIN_TOKEN
ADMIN_TOKEN="seu_token_admin_secreto"
